# 백엔드 공개 API (홈페이지용)
# - 로컬: 백엔드를 포트 8001로 띄운 뒤 아래처럼 설정
#   NEXT_PUBLIC_API_URL=http://localhost:8001
# - 프로덕션 기본값: https://api.inde.kr
NEXT_PUBLIC_API_URL=

# OG·canonical 절대 URL (비우면 https://www.inde.kr). 로컬 미리보기: http://local.inde.kr:3001
# NEXT_PUBLIC_SITE_ORIGIN=http://local.inde.kr:3001

# Hero 메인 배너 — sysCode 하위 SID (부모 SYS26320B003).
# 비우면 공개 API by_parent로 하위 목록을 받아, 이름에「메인」이 들어간 이벤트 유형 sid를 자동 사용(§12.1 eventBannerPlan.md).
# 여러 유형을 쓰거나 자동 추론 대신 고정하려면 아래에 실제 sid를 넣는다.
# NEXT_PUBLIC_HERO_EVENT_TYPE_CODE=SYS26320B004

# Figma 이미지 export (scripts/export-figma-images.mjs)
# https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=faaPr93HWq1MitjeIhWdrO
