# 백엔드 공개 API (홈페이지용)
# - 로컬 next dev: 비우면 동일 출처 프록시(next.config.js rewrites → 127.0.0.1:8001). CORS Network Error 방지.
# - 직접 API 호출이 필요하면: NEXT_PUBLIC_API_URL=http://localhost:8001
# - 프록시 대상 포트만 바꿀 때: INDE_PUBLIC_API_PROXY_TARGET=http://127.0.0.1:8001
# - 프로덕션 기본값(빌드): https://api.inde.kr
NEXT_PUBLIC_API_URL=

# OG·canonical 절대 URL (비우면 https://www.inde.kr). 로컬 미리보기: http://local.inde.kr:3001
# NEXT_PUBLIC_SITE_ORIGIN=http://local.inde.kr:3001

# Google Analytics 4 측정 ID (비우면 gtag 미삽입). 예: G-XXXXXXXXXX — googleAnalyticsPlan.md
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 카카오톡 채널 추가 플로팅 버튼(상세 페이지) — 둘 다 비우면 미표시. kakaoChannelButtonPlan.md
# NEXT_PUBLIC_KAKAO_JS_KEY=
# NEXT_PUBLIC_KAKAO_CHANNEL_PUBLIC_ID=

# Hero 메인 배너 — sysCode 하위 SID (부모 SYS26320B003).
# 비우면 공개 API by_parent로 하위 목록을 받아, 이름에「메인」이 들어간 이벤트 유형 sid를 자동 사용(§12.1 eventBannerPlan.md).
# 여러 유형을 쓰거나 자동 추론 대신 고정하려면 아래에 실제 sid를 넣는다.
# NEXT_PUBLIC_HERO_EVENT_TYPE_CODE=SYS26320B004

# Figma 이미지 export (scripts/export-figma-images.mjs)
# https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=faaPr93HWq1MitjeIhWdrO
